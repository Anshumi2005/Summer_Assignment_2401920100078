#include <stdbool.h>
#include <string.h>
bool isAnagram(char* s,char* t) {
    int n= strlen(s);
    int m =strlen(t);
    if (n !=m) {
        return false;
    }
    for (int i= 0; i< n; i++) {
        int find =0;
        for (int j= 0; j< m; j++) {
            if (s[i] == t[j]) {
                t[j] ='*';   
                find = 1;
                break;
            }
        }
        if (!find) {
            return false;
        }
    }
    return true;
}
