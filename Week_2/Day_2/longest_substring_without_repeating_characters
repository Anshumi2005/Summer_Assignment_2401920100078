int lengthOfLongestSubstring(char *s) {
    int n = strlen(s);
    int maxLen = 0;
    for (int i = 0; i < n; i++) {
        int freq[256] = {0};

        for (int j = i; j < n; j++) {
            if (freq[(unsigned char)s[j]] == 1) {
                break;
            }
            freq[(unsigned char)s[j]] = 1;

            if (j - i + 1 > maxLen) {
                maxLen = j - i + 1;
            }
        }
    }
    return maxLen;
}  
